@inherits LayoutComponentBase

@using Zonit.Extensions.Identity
@using Zonit.Extensions.Website.Abstractions.Navigations.Types

@using Zonit.Services.Dashboard
@using Zonit.Services.Dashboard.Areas.Dashboard.Components

@using Data
@using Zonit.Services.Dashboard.Components

@inject ICultureProvider Culture
@inject IAuthenticatedProvider Authenticated
@inject IExtensionManager ExtensionManager
@inject IExtensionDrawerManager DrawerManager

<MudThemeProvider Theme="@_currentMudTheme" @ref="@_mudThemeProvider" IsDarkMode="_isDarkMode" />
<MudDialogProvider FullWidth="true" Position="DialogPosition.Center" MaxWidth="MaxWidth.ExtraSmall"
                   CloseOnEscapeKey="true" />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudRTLProvider RightToLeft="RightToLeft">
    <MudLayout>

        @if (ProgressTask)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="z-index: 2;" Size="Size.Small" />
        }

        <Navbar MudThemeProvider="@_mudThemeProvider" Breadcrumbs="@_breadcrumbItems" @bind-DrawerOpen="@_drawerOpen"
                @bind-DrawerRightOpen="@_drawerRightOpen" Width="@_width" Hegith="@_height" />

        <MudSwipeArea OnSwipeEnd="@OnSwipe" Style="width: 100%; touch-action: pan-y" PreventDefault="false">
            @* Left Drawer - Main Navigation *@
            <MudDrawer @bind-Open="_drawerOpen" Variant="_drawerVariant" OpenMiniOnHover="_drawerOpenMin"
                       Anchor="Anchor.Start" Elevation="2">
                <MudDrawerHeader>
                    <a Href="/">
                        <MudText Typo="Typo.h5" Class="mt-1">@settingsProvider.Settings.Title</MudText>
                    </a>
                </MudDrawerHeader>
                <MudNavMenu Rounded="true" Margin="Margin.Normal" Class="pa-2">
                    <NavMenu Area="DashboardAreaType" Position="NavigationPosition.Left" />

                    <ExtensionView Name="@Extensions.SocialMedia">
                        <SocialMediaLinks />
                    </ExtensionView>
                </MudNavMenu>
            </MudDrawer>

            @* Right Drawer - User Settings & Extensions *@
            <MudDrawer @bind-Open="_drawerRightOpen" Anchor="Anchor.End" Elevation="2">
                <MudNavMenu Bordered="true">
                    <ExtensionView Name="@Extensions.Identity">
                        @if (Authenticated.User is not null)
                        {
                            <UserProfileHeader User="@Authenticated.User" />
                            <MudDivider Class="my-2" />
                        }
                    </ExtensionView>

                    <ThemeSelector MudThemeProvider="@_mudThemeProvider" @bind-DarkMode="@_isDarkMode" />

                    <ExtensionView Name="@Extensions.Organizations">
                        <ChangeOrganization />
                    </ExtensionView>

                    <ExtensionView Name="@Extensions.Projects">
                        <ChangeProjects />
                    </ExtensionView>

                    <ExtensionView Name="@Extensions.Cultures">
                        <CultureButton />
                    </ExtensionView>

                    <NavMenu Area="DashboardAreaType" Position="NavigationPosition.Right" />
                </MudNavMenu>
            </MudDrawer>

            <MudMainContent>
                <div style="min-height: 100vh; margin-top: 20px; margin-bottom: 20px;" data-clarity-unmask="true">
                    @Body
                </div>
            </MudMainContent>
        </MudSwipeArea>

        @* Extension Drawers *@
        <ExtensionView Name="@Extensions.Task">
            <TaskDrawer />
        </ExtensionView>

        <ExtensionView Name="@Extensions.Cultures">
            <CultureDrawer />
        </ExtensionView>

    </MudLayout>
</MudRTLProvider>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    bool _drawerOpen = true;
    bool _drawerOpenMin = false;
    DrawerVariant _drawerVariant = DrawerVariant.Responsive;
    bool _drawerRightOpen = true;
    bool _isDarkMode = false;
    MudThemeProvider _mudThemeProvider = null!;
    bool RightToLeft = false;

    public void OnSwipe(SwipeEventArgs args)
    {
        // Only handle swipe on mobile devices
        if (_width >= 1024)
            return;

        if (args.SwipeDirection == SwipeDirection.LeftToRight)
        {
            if (!_drawerOpen)
            {
                _drawerOpen = true;
                _drawerRightOpen = false;
            }
            else
            {
                _drawerOpen = false;
            }
        }
        else if (args.SwipeDirection == SwipeDirection.RightToLeft)
        {
            if (!_drawerRightOpen)
            {
                _drawerRightOpen = true;
                _drawerOpen = false;
            }
            else
            {
                _drawerRightOpen = false;
            }
        }
    }
}