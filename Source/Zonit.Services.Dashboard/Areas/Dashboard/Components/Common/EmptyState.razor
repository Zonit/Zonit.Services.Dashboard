@*
    EmptyState - Standard empty state component for lists and tables.
    Use when there is no data to display.
*@

@inject ICultureProvider Culture

<div class="d-flex flex-column align-center justify-center pa-8" style="min-height: @MinHeight;">
    <MudIcon Icon="@Icon" Size="Size.Large"
             Style="font-size: 64px; color: var(--mud-palette-text-disabled); margin-bottom: 16px;" />

    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-2" Style="font-weight: 500;">
        @Culture.Translate(Title)
    </MudText>

    @if (!string.IsNullOrEmpty(Description))
    {
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary" Style="max-width: 320px;">
            @Culture.Translate(Description)
        </MudText>
    }

    @if (Actions is not null)
    {
        <div class="mt-4">
            @Actions
        </div>
    }
</div>

@code {
    /// <summary>
    /// Icon to display.
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = Icons.Material.Outlined.Inbox;

    /// <summary>
    /// Main title message.
    /// </summary>
    [Parameter]
    public string Title { get; set; } = "No data";

    /// <summary>
    /// Optional description message.
    /// </summary>
    [Parameter]
    public string? Description { get; set; }

    /// <summary>
    /// Minimum height of the container.
    /// </summary>
    [Parameter]
    public string MinHeight { get; set; } = "300px";

    /// <summary>
    /// Optional action buttons.
    /// </summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }
}